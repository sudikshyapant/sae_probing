#!/usr/bin/env python3
"""Remove malformed metadata.widgets from staged notebooks before commit."""
import json
import subprocess
import sys

staged = subprocess.run(
    ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
    capture_output=True, text=True,
).stdout.splitlines()

for path in staged:
    if not path.endswith(".ipynb"):
        continue
    with open(path) as f:
        nb = json.load(f)
    widgets = nb.get("metadata", {}).get("widgets", {})
    if widgets and "state" not in widgets:
        nb["metadata"].pop("widgets")
        with open(path, "w") as f:
            json.dump(nb, f, indent=1)
        subprocess.run(["git", "add", path])
        print(f"Fixed metadata.widgets in {path}")

sys.exit(0)
